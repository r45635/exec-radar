# Application
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/exec_radar

# API Keys (set your own values – never commit real secrets)
# OPENAI_API_KEY=sk-...
# SERP_API_KEY=...

# Worker settings
WORKER_INTERVAL_SECONDS=3600

# Scoring
MIN_FIT_SCORE=0.0
MAX_FIT_SCORE=100.0
