# Exec Radar – Environment Variables
# Copy to .env and fill in real values.

# ============================================================================
# Application Settings
# ============================================================================

# App name (for logging)
EXEC_RADAR_APP_NAME="Exec Radar"

# Debug mode (enables verbose output, reloads)
EXEC_RADAR_DEBUG=false

# API server address
EXEC_RADAR_API_HOST=0.0.0.0
EXEC_RADAR_API_PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
EXEC_RADAR_LOG_LEVEL=INFO

# ============================================================================
# Data Collection
# ============================================================================

# Collector choice: 'mock' (default) or 'greenhouse'
# Use 'mock' for testing with sample data.
# Use 'greenhouse' to fetch real jobs from Greenhouse Boards API.
EXEC_RADAR_COLLECTOR=mock

# Greenhouse Boards API board token (required if EXEC_RADAR_COLLECTOR=greenhouse)
# Examples: discord, cloudflare, figma, notion, stripe, remote
# Find board tokens at: https://boards.greenhouse.io/<board_token>
EXEC_RADAR_GREENHOUSE_BOARD=discord

# ============================================================================
# Target Profile
# ============================================================================

# Path to custom target profile YAML file (optional)
# If not set, uses default profile (all seniorities, all locations, etc.)
# Example: ./examples/sample_profile.yaml
# EXEC_RADAR_TARGET_PROFILE=./examples/sample_profile.yaml

# ============================================================================
# Database (Optional)
# ============================================================================

# Database connection string (optional; omit for in-memory only)
# Supported databases:
#   - PostgreSQL (recommended): postgresql+asyncpg://user:pass@host:5432/db
#   - MySQL: mysql+aiomysql://user:pass@host:3306/db
#   - SQLite (dev only): sqlite+aiosqlite:///./exec_radar.db
#
# If set:
#   1. Run: alembic upgrade head
#   2. Pipeline persists collected, normalized, and scored jobs
#   3. API serves from database instead of re-running pipeline
#
# If not set:
#   - Pipeline runs in-memory each time
#   - No persistence across restarts
# EXEC_RADAR_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/exec_radar

# ============================================================================
# Dashboard Preferences
# ============================================================================

# Database path for dashboard preferences (favorites, dismissed jobs)
# Default: .data/dashboard_preferences.sqlite3
# EXEC_RADAR_DASHBOARD_PREFS_DB=.data/dashboard_preferences.sqlite3
